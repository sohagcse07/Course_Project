<odoo>


  <template id="expense_custom_reportt">

   <t t-call="web.html_container">

        <t t-foreach="docs" t-as="doc">
        <t t-call="web.external_layout">


            <div class="page">

            <h2>Expense:<span t-field="doc.name"/></h2>
            <p>Employee: <span t-field="doc.employee_id"/></p>
            <p>Category: <span t-field="doc.product_id"/></p>
            <p>Amount: <span t-field="doc.total_amount" t-options="{'widget': 'monetary'}"/></p>
            <p>Date: <span t-field="doc.date"/></p>

            </div>
        </t>
        </t>
    </t>

  </template>
  
</odoo>